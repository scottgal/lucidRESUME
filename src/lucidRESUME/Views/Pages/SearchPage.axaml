<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:lucidRESUME.ViewModels.Pages"
             x:DataType="vm:SearchPageViewModel"
             x:Class="lucidRESUME.Views.Pages.SearchPage">

  <Grid RowDefinitions="Auto,*" Background="#181825">

    <!-- Top input panel -->
    <ScrollViewer Grid.Row="0" MaxHeight="420">
      <StackPanel Margin="24,16" Spacing="16">

        <TextBlock Text="Add Job" FontSize="22" FontWeight="Bold" Foreground="#CDD6F4"/>

        <!-- URL fetch card -->
        <Border Background="#313244" BorderBrush="#45475A" BorderThickness="1"
                CornerRadius="8" Padding="0">
          <Grid ColumnDefinitions="3,*">
            <Border Grid.Column="0" Background="#89B4FA" CornerRadius="3,0,0,3" MinHeight="1"/>
            <StackPanel Grid.Column="1" Margin="20,16" Spacing="10">
              <TextBlock Text="Paste a Job URL" FontSize="13" FontWeight="SemiBold" Foreground="#CDD6F4"/>
              <TextBlock Text="The app will fetch and parse the job description automatically."
                         FontSize="11" Foreground="#6C7086" TextWrapping="Wrap"/>
              <Grid ColumnDefinitions="*,8,Auto">
                <TextBox Grid.Column="0" Text="{Binding JobUrl}"
                         Watermark="https://example.com/jobs/123"
                         Background="#1E1E2E" BorderBrush="#45475A"
                         Foreground="#CDD6F4" CornerRadius="6" Padding="10,8"/>
                <Button Grid.Column="2" Content="Fetch"
                        Command="{Binding FetchUrlCommand}"
                        IsEnabled="{Binding !IsLoading}"
                        Padding="16,8"/>
              </Grid>

              <!-- Manual paste fallback banner -->
              <Border Background="#2A2020" CornerRadius="6" Padding="12,8"
                      IsVisible="{Binding NeedsManualText}">
                <StackPanel Spacing="4">
                  <TextBlock Text="⚠  This site requires manual paste"
                             FontSize="12" FontWeight="SemiBold" Foreground="#FAB387"
                             FontFamily="Segoe UI Emoji,Apple Color Emoji,Noto Color Emoji"/>
                  <TextBlock FontSize="11" Foreground="#A6ADC8" TextWrapping="Wrap">
                    <Run Text="Open"/>
                    <Run Text="{Binding ManualUrl}" Foreground="#89B4FA" TextDecorations="Underline"/>
                    <Run Text="in your browser, copy the job description, and paste it in the text box below."/>
                  </TextBlock>
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Paste text card -->
        <Border Background="#313244" BorderBrush="#45475A" BorderThickness="1"
                CornerRadius="8" Padding="0">
          <Grid ColumnDefinitions="3,*">
            <Border Grid.Column="0" Background="#CBA6F7" CornerRadius="3,0,0,3" MinHeight="1"/>
            <StackPanel Grid.Column="1" Margin="20,16" Spacing="10">
              <TextBlock Text="Paste Job Description Text" FontSize="13" FontWeight="SemiBold" Foreground="#CDD6F4"/>
              <TextBlock Text="Copy the full job posting text and paste it here."
                         FontSize="11" Foreground="#6C7086" TextWrapping="Wrap"/>
              <TextBox Text="{Binding PastedText}"
                       Watermark="Paste job description here…"
                       AcceptsReturn="True" TextWrapping="Wrap" Height="120"
                       Background="#1E1E2E" BorderBrush="#45475A"
                       Foreground="#CDD6F4" CornerRadius="6" Padding="10,8"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"/>
              <Button Content="Add Job" Command="{Binding AddTextCommand}"
                      IsEnabled="{Binding !IsLoading}"
                      HorizontalAlignment="Right" Padding="16,8"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Status -->
        <TextBlock Text="{Binding StatusMessage}" Foreground="#A6ADC8" FontSize="12"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

      </StackPanel>
    </ScrollViewer>

    <!-- Saved jobs list -->
    <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="24,0,24,16">

      <TextBlock Grid.Row="0" Text="Saved Jobs" FontSize="14" FontWeight="SemiBold"
                 Foreground="#89B4FA" Margin="0,0,0,8"/>

      <!-- Empty state -->
      <TextBlock Grid.Row="1" Text="No jobs saved yet — fetch a URL or paste a job description above."
                 Foreground="#45475A" FontSize="13"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 IsVisible="{Binding !SavedJobs.Count}"/>

      <!-- Job list -->
      <ScrollViewer Grid.Row="1" IsVisible="{Binding SavedJobs.Count}">
        <ItemsControl ItemsSource="{Binding SavedJobs}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:SavedJobItem">
              <Border Background="#313244" BorderBrush="#45475A" BorderThickness="1"
                      CornerRadius="6" Padding="12,8" Margin="0,0,0,6">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock FontWeight="SemiBold" Foreground="#CDD6F4" FontSize="13">
                      <Run Text="{Binding Title}"/>
                      <Run Text=" — " Foreground="#6C7086"/>
                      <Run Text="{Binding Company}"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding Location}" Foreground="#6C7086" FontSize="11"
                                 IsVisible="{Binding Location, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                      <Border Background="#1E1E2E" CornerRadius="4" Padding="5,1">
                        <TextBlock Text="{Binding Source}" Foreground="#89B4FA" FontSize="10"/>
                      </Border>
                    </StackPanel>
                  </StackPanel>
                  <Button Grid.Column="1" Content="✕"
                          Command="{Binding $parent[UserControl].((vm:SearchPageViewModel)DataContext).RemoveJobCommand}"
                          CommandParameter="{Binding}"
                          Width="28" Height="28" Padding="0"
                          Foreground="#6C7086" Background="Transparent"
                          BorderThickness="0" VerticalAlignment="Top"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>

  </Grid>
</UserControl>
