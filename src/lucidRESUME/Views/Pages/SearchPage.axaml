<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:lucidRESUME.ViewModels.Pages"
             x:DataType="vm:SearchPageViewModel"
             x:Class="lucidRESUME.Views.Pages.SearchPage">

  <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource LrPageBgBrush}">

    <!-- Top input panel -->
    <ScrollViewer Grid.Row="0" MaxHeight="420">
      <StackPanel Margin="24,16" Spacing="16">

        <TextBlock Text="Add Job" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource LrPrimaryTextBrush}"/>

        <!-- URL fetch card -->
        <Border Background="{DynamicResource LrSurfaceBgBrush}" BorderBrush="{DynamicResource LrBorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="0">
          <Grid ColumnDefinitions="3,*">
            <Border Grid.Column="0" Background="{DynamicResource LrAccentBlueBrush}" CornerRadius="3,0,0,3" MinHeight="1"/>
            <StackPanel Grid.Column="1" Margin="20,16" Spacing="10">
              <TextBlock Text="Paste a Job URL" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource LrPrimaryTextBrush}"/>
              <TextBlock Text="The app will fetch and parse the job description automatically."
                         FontSize="11" Foreground="{DynamicResource LrSubtleTextBrush}" TextWrapping="Wrap"/>
              <Grid ColumnDefinitions="*,8,Auto">
                <TextBox Grid.Column="0" Text="{Binding JobUrl}"
                         Watermark="https://example.com/jobs/123"
                         CornerRadius="6" Padding="10,8"/>
                <Button Grid.Column="2" Content="Fetch"
                        Command="{Binding FetchUrlCommand}"
                        IsEnabled="{Binding !IsLoading}"
                        Padding="16,8"/>
              </Grid>

              <!-- Manual paste fallback banner -->
              <Border Background="{DynamicResource LrWarningBannerBgBrush}" CornerRadius="6" Padding="12,8"
                      IsVisible="{Binding NeedsManualText}">
                <StackPanel Spacing="4">
                  <TextBlock Text="⚠  This site requires manual paste"
                             FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource LrAccentPeachBrush}"
                             FontFamily="Segoe UI Emoji,Apple Color Emoji,Noto Color Emoji"/>
                  <TextBlock FontSize="11" Foreground="{DynamicResource LrSecondaryTextBrush}" TextWrapping="Wrap">
                    <Run Text="Open"/>
                    <Run Text="{Binding ManualUrl}" Foreground="{DynamicResource LrAccentBlueBrush}" TextDecorations="Underline"/>
                    <Run Text="in your browser, copy the job description, and paste it in the text box below."/>
                  </TextBlock>
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Paste text card -->
        <Border Background="{DynamicResource LrSurfaceBgBrush}" BorderBrush="{DynamicResource LrBorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="0">
          <Grid ColumnDefinitions="3,*">
            <Border Grid.Column="0" Background="{DynamicResource LrAccentPurpleBrush}" CornerRadius="3,0,0,3" MinHeight="1"/>
            <StackPanel Grid.Column="1" Margin="20,16" Spacing="10">
              <TextBlock Text="Paste Job Description Text" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource LrPrimaryTextBrush}"/>
              <TextBlock Text="Copy the full job posting text and paste it here."
                         FontSize="11" Foreground="{DynamicResource LrSubtleTextBrush}" TextWrapping="Wrap"/>
              <TextBox Text="{Binding PastedText}"
                       Watermark="Paste job description here…"
                       AcceptsReturn="True" TextWrapping="Wrap" Height="120"
                       CornerRadius="6" Padding="10,8"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"/>
              <Button Content="Add Job" Command="{Binding AddTextCommand}"
                      IsEnabled="{Binding !IsLoading}"
                      HorizontalAlignment="Right" Padding="16,8"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Status -->
        <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource LrSecondaryTextBrush}" FontSize="12"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

      </StackPanel>
    </ScrollViewer>

    <!-- Saved jobs list -->
    <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="24,0,24,16">

      <TextBlock Grid.Row="0" Text="Saved Jobs" FontSize="14" FontWeight="SemiBold"
                 Foreground="{DynamicResource LrAccentBlueBrush}" Margin="0,0,0,8"/>

      <!-- Empty state -->
      <TextBlock Grid.Row="1" Text="No jobs saved yet — fetch a URL or paste a job description above."
                 Foreground="{DynamicResource LrSubtleTextBrush}" FontSize="13"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 IsVisible="{Binding !SavedJobs.Count}"/>

      <!-- Job list -->
      <ScrollViewer Grid.Row="1" IsVisible="{Binding SavedJobs.Count}">
        <ItemsControl ItemsSource="{Binding SavedJobs}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:SavedJobItem">
              <Border Background="{DynamicResource LrSurfaceBgBrush}" BorderBrush="{DynamicResource LrBorderBrush}" BorderThickness="1"
                      CornerRadius="6" Padding="12,8" Margin="0,0,0,6">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource LrPrimaryTextBrush}" FontSize="13">
                      <Run Text="{Binding Title}"/>
                      <Run Text=" — " Foreground="{DynamicResource LrSubtleTextBrush}"/>
                      <Run Text="{Binding Company}"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding Location}" Foreground="{DynamicResource LrSubtleTextBrush}" FontSize="11"
                                 IsVisible="{Binding Location, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                      <Border Background="{DynamicResource LrCardBgBrush}" CornerRadius="4" Padding="5,1">
                        <TextBlock Text="{Binding Source}" Foreground="{DynamicResource LrAccentBlueBrush}" FontSize="10"/>
                      </Border>
                    </StackPanel>
                  </StackPanel>
                  <Button Grid.Column="1" Content="✕"
                          Command="{Binding $parent[UserControl].((vm:SearchPageViewModel)DataContext).RemoveJobCommand}"
                          CommandParameter="{Binding}"
                          Width="28" Height="28" Padding="0"
                          Foreground="{DynamicResource LrSubtleTextBrush}" Background="Transparent"
                          BorderThickness="0" VerticalAlignment="Top"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>

    <!-- Search Watches -->
    <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource LrBorderBrush}" Padding="24,12">
      <StackPanel Spacing="8">
        <TextBlock Text="Search Watches" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource LrAccentPurpleBrush}"/>

        <!-- Create watch -->
        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" Margin="0,0,0,4">
          <TextBox Grid.Column="0" Text="{Binding NewWatchQuery}" Watermark="Watch query (e.g. .NET Azure remote)..."
                   CornerRadius="4" Padding="8,4" FontSize="12"/>
          <CheckBox Grid.Column="1" Content="Salary" IsChecked="{Binding NewWatchRequireSalary}"
                    Margin="8,0" VerticalAlignment="Center" FontSize="11"/>
          <CheckBox Grid.Column="2" Content="Remote" IsChecked="{Binding NewWatchRequireRemote}"
                    Margin="0,0,8,0" VerticalAlignment="Center" FontSize="11"/>
          <TextBox Grid.Column="3" Text="{Binding NewWatchPollMinutes}" Width="50"
                   Watermark="min" CornerRadius="4" Padding="4,4" FontSize="11" VerticalAlignment="Center"/>
          <Button Grid.Column="4" Content="Watch" Command="{Binding CreateWatchCommand}"
                  Padding="10,4" FontSize="11" Margin="8,0,0,0"/>
        </Grid>

        <!-- Active watches -->
        <ItemsControl ItemsSource="{Binding Watches}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:WatchItem">
              <Border Background="{DynamicResource LrSurfaceBgBrush}" CornerRadius="4" Padding="8,4" Margin="0,0,0,3">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                  <Border Grid.Column="0" Background="{DynamicResource LrAccentPurpleBrush}" CornerRadius="3"
                          Padding="4,1" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.8">
                    <TextBlock Text="{Binding PollMinutes, StringFormat='{}{0}m'}" FontSize="8" Foreground="White"/>
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Query}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource LrPrimaryTextBrush}"/>
                    <TextBlock FontSize="9" Foreground="{DynamicResource LrSubtleTextBrush}">
                      <Run Text="Last: "/><Run Text="{Binding LastPolled}"/>
                      <Run Text=" | "/><Run Text="{Binding LastMatches}"/><Run Text=" matches"/>
                    </TextBlock>
                  </StackPanel>
                  <Button Grid.Column="3" Content="Delete"
                          Command="{Binding $parent[ItemsControl].((vm:SearchPageViewModel)DataContext).DeleteWatchCommand}"
                          CommandParameter="{Binding}"
                          Padding="4,2" FontSize="10" Margin="4,0"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>

  </Grid>
</UserControl>
