<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:lucidRESUME.ViewModels.Pages"
             x:DataType="vm:JobsPageViewModel"
             x:Class="lucidRESUME.Views.Pages.JobsPage">

  <Grid RowDefinitions="Auto,*">

    <!-- Search toolbar -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="16,10,16,8">
      <TextBox Text="{Binding SearchQuery}"
               Watermark="Search jobs (e.g. C# developer London)…"
               Width="380" VerticalAlignment="Center"/>
      <Button Content="Search" Command="{Binding SearchCommand}" VerticalAlignment="Center"/>
      <ProgressBar IsVisible="{Binding IsLoading}" IsIndeterminate="True"
                   Width="100" VerticalAlignment="Center"/>
      <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="#A6ADC8"
                 IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    </StackPanel>

    <!-- Main content area -->
    <Grid Grid.Row="1" ColumnDefinitions="300,*">

      <!-- LEFT: job list -->
      <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="#313244">
        <Panel>

          <!-- Empty state -->
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6"
                      IsVisible="{Binding !Jobs.Count}">
            <TextBlock Text="No jobs yet." Foreground="#6C7086" FontSize="14"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Run a search above." Foreground="#45475A" FontSize="12"
                       HorizontalAlignment="Center"/>
          </StackPanel>

          <!-- Job list -->
          <ScrollViewer IsVisible="{Binding Jobs.Count}">
            <ItemsControl ItemsSource="{Binding Jobs}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:JobListItem">
                  <Button Command="{Binding $parent[ItemsControl].((vm:JobsPageViewModel)DataContext).SelectJobCommand}"
                          CommandParameter="{Binding}"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="12,8"
                          Margin="0,0,0,1">
                    <StackPanel Spacing="3">
                      <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                 Foreground="#CDD6F4" FontSize="13" TextWrapping="Wrap"/>
                      <TextBlock FontSize="11" Foreground="#A6ADC8">
                        <Run Text="{Binding Company}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding Location}"/>
                      </TextBlock>
                      <TextBlock FontSize="10" Foreground="#6C7086"
                                 Text="{Binding SkillScore, StringFormat='Match: {0:P0}'}"/>
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

        </Panel>
      </Border>

      <!-- RIGHT: job detail -->
      <Panel Grid.Column="1">

        <!-- No selection placeholder -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6"
                    IsVisible="{Binding SelectedJob, Converter={x:Static ObjectConverters.IsNull}}">
          <TextBlock Text="Select a job to view details." Foreground="#6C7086" FontSize="14"/>
        </StackPanel>

        <!-- Job detail -->
        <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="20,16"
              IsVisible="{Binding SelectedJob, Converter={x:Static ObjectConverters.IsNotNull}}">

          <!-- Header -->
          <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="{Binding SelectedJobTitle}" FontSize="20" FontWeight="Bold"
                       Foreground="#CDD6F4" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="{Binding SelectedJobCompany}" Foreground="#A6ADC8" FontSize="14"/>
              <TextBlock Text="·" Foreground="#45475A" FontSize="14"/>
              <TextBlock Text="{Binding SelectedJobLocation}" Foreground="#A6ADC8" FontSize="14"/>
              <Border Background="#1E3A5F" CornerRadius="10" Padding="8,2"
                      IsVisible="{Binding SelectedJobIsRemote}">
                <TextBlock Text="Remote" Foreground="#89B4FA" FontSize="11"/>
              </Border>
            </StackPanel>
          </StackPanel>

          <!-- Description -->
          <ScrollViewer Grid.Row="1">
            <TextBlock Text="{Binding SelectedJobDescription}"
                       TextWrapping="Wrap" Foreground="#BAC2DE" FontSize="12" LineHeight="18"/>
          </ScrollViewer>

          <!-- Aspect voting panel -->
          <StackPanel Grid.Row="2" Spacing="4" Margin="0,12,0,4"
                      IsVisible="{Binding SelectedJobAspects.Count}">

            <TextBlock Text="Rate Aspects" FontSize="12" FontWeight="SemiBold"
                       Foreground="#89B4FA" Margin="0,0,0,4"/>

            <ItemsControl ItemsSource="{Binding SelectedJobAspects}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:AspectVoteItem">
                  <Border Background="#1E1E2E" CornerRadius="6" Padding="8,5" Margin="0,0,0,4">
                    <Grid ColumnDefinitions="Auto,*,Auto">

                      <!-- Type badge -->
                      <Border Grid.Column="0" Background="#2A2A3E" CornerRadius="4"
                              Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding TypeLabel}" FontSize="10"
                                   Foreground="#6C7086" FontWeight="SemiBold"/>
                      </Border>

                      <!-- Value + score -->
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                  VerticalAlignment="Center">
                        <TextBlock Text="{Binding Value}" Foreground="#CDD6F4" FontSize="12"
                                   VerticalAlignment="Center"/>
                        <Border Background="#2A2A3E" CornerRadius="4" Padding="5,1"
                                VerticalAlignment="Center">
                          <TextBlock Text="{Binding Score}" FontSize="11" FontWeight="Bold"
                                     Foreground="#6C7086"/>
                        </Border>
                      </StackPanel>

                      <!-- Vote buttons -->
                      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                  VerticalAlignment="Center">
                        <Button Content="▲"
                                Command="{Binding $parent[ItemsControl].((vm:JobsPageViewModel)DataContext).VoteUpCommand}"
                                CommandParameter="{Binding}"
                                Background="Transparent" Foreground="#A6E3A1"
                                FontSize="12" Padding="6,2"
                                ToolTip.Tip="Like — boosts similar jobs"/>
                        <Button Content="▼"
                                Command="{Binding $parent[ItemsControl].((vm:JobsPageViewModel)DataContext).VoteDownCommand}"
                                CommandParameter="{Binding}"
                                Background="Transparent" Foreground="#F38BA8"
                                FontSize="12" Padding="6,2"
                                ToolTip.Tip="Dislike — hides at -3"/>
                      </StackPanel>

                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>

          <!-- Actions -->
          <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button Content="Apply / Tailor Resume"
                    Command="{Binding TailorSelectedJobCommand}"
                    Background="#1E3A5F" Foreground="#89B4FA"
                    Padding="16,8"/>
          </StackPanel>

        </Grid>
      </Panel>

    </Grid>
  </Grid>
</UserControl>
