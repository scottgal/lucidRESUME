<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:lucidRESUME.ViewModels.Pages"
             x:DataType="vm:ProfilePageViewModel"
             x:Class="lucidRESUME.Views.Pages.ProfilePage">
  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
    <TextBlock Text="Profile" FontSize="24" HorizontalAlignment="Center"/>
    <TextBlock Text="Manage your profile settings here." HorizontalAlignment="Center" Foreground="#A6ADC8"/>
  </StackPanel>
</UserControl>
