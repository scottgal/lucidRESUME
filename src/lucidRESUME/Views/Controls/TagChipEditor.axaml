<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:lucidRESUME.Views.Controls"
             xmlns:models="using:lucidRESUME.Core.Models.Profile"
             x:Class="lucidRESUME.Views.Controls.TagChipEditor">

  <Border Background="#1E1E2E"
          BorderBrush="#6C7086"
          BorderThickness="1"
          CornerRadius="6"
          MinHeight="36"
          Padding="4,2">

    <WrapPanel x:Name="ChipWrapPanel" Orientation="Horizontal">

      <!-- Chips are added programmatically by code-behind -->
      <!-- This TextBox is the "add tag" input at the end of the chip list -->
      <TextBox x:Name="AddTagBox"
               Watermark="Add..."
               MinWidth="80"
               MaxWidth="160"
               FontSize="12"
               Foreground="#CDD6F4"
               Background="Transparent"
               BorderThickness="0"
               Padding="4,3"
               VerticalAlignment="Center"
               Margin="2,2,0,2"/>

    </WrapPanel>
  </Border>

</UserControl>
