<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="lucidRESUME.Views.Controls.WorkStyleToggleGroup">

  <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">

    <CheckBox x:Name="RemoteCheckBox"
              Content="Remote"/>

    <CheckBox x:Name="HybridCheckBox"
              Content="Hybrid"/>

    <CheckBox x:Name="OnsiteCheckBox"
              Content="Onsite"/>

    <Button x:Name="RemoteOnlyButton"
            Content="Remote Only"
            Padding="10,4"
            FontSize="12"
            VerticalAlignment="Center"/>

  </StackPanel>

</UserControl>
