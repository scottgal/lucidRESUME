<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:lucidRESUME.ViewModels"
        xmlns:local="using:lucidRESUME"
        x:DataType="vm:MainWindowViewModel"
        x:Class="lucidRESUME.MainWindow"
        Title="lucidRESUME" Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        DragDrop.AllowDrop="True">

  <Window.Styles>
    <Style Selector="Button.nav-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="8,7"/>
      <Setter Property="Foreground" Value="{DynamicResource LrNavTextBrush}"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>
    <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource LrNavHoverBgBrush}"/>
    </Style>
  </Window.Styles>

  <Window.Resources>
    <local:NavIsActiveConverter x:Key="NavIsActive"/>
  </Window.Resources>

  <Grid ColumnDefinitions="200,*">

    <!-- Sidebar -->
    <Border Grid.Column="0" Background="{DynamicResource LrNavBgBrush}" Padding="8">
      <DockPanel>

      <!-- Status at bottom of sidebar -->
      <Border DockPanel.Dock="Bottom" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource LrBorderBrush}"
              Margin="0,4,0,0" Padding="6,6,6,4">
        <StackPanel Spacing="2">
          <TextBlock Text="Services" FontSize="9" Foreground="{DynamicResource LrSubtleTextBrush}" FontWeight="SemiBold" Margin="0,0,0,1"/>
          <StackPanel Orientation="Horizontal" Spacing="3">
            <Ellipse Width="5" Height="5" VerticalAlignment="Center"
                     Fill="{Binding EmbeddingColor, Converter={x:Static local:StatusColorConverter.Instance}}"/>
            <TextBlock Text="{Binding EmbeddingLabel}" FontSize="9" Foreground="{DynamicResource LrNavTextBrush}"
                       TextTrimming="CharacterEllipsis" MaxWidth="165"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="3">
            <Ellipse Width="5" Height="5" VerticalAlignment="Center"
                     Fill="{Binding NerColor, Converter={x:Static local:StatusColorConverter.Instance}}"/>
            <TextBlock Text="{Binding NerLabel}" FontSize="9" Foreground="{DynamicResource LrNavTextBrush}"
                       TextTrimming="CharacterEllipsis" MaxWidth="165"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="3">
            <Ellipse Width="5" Height="5" VerticalAlignment="Center"
                     Fill="{Binding OllamaColor, Converter={x:Static local:StatusColorConverter.Instance}}"/>
            <TextBlock Text="{Binding OllamaLabel}" FontSize="9" Foreground="{DynamicResource LrNavTextBrush}"
                       TextTrimming="CharacterEllipsis" MaxWidth="165"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="3">
            <Ellipse Width="5" Height="5" VerticalAlignment="Center"
                     Fill="{Binding DoclingColor, Converter={x:Static local:StatusColorConverter.Instance}}"/>
            <TextBlock Text="{Binding DoclingLabel}" FontSize="9" Foreground="{DynamicResource LrNavTextBrush}"
                       TextTrimming="CharacterEllipsis" MaxWidth="165"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="3">
            <Ellipse Width="5" Height="5" VerticalAlignment="Center" Fill="{DynamicResource LrStatusGreenBrush}"/>
            <TextBlock Text="{Binding StoreLabel}" FontSize="9" Foreground="{DynamicResource LrNavTextBrush}"/>
          </StackPanel>
          <TextBlock Text="{Binding WarningMessage}" FontSize="8" Foreground="{DynamicResource LrAccentYellowBrush}"
                     TextWrapping="Wrap" IsVisible="{Binding WarningMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                     Margin="0,2,0,0"/>
        </StackPanel>
      </Border>

      <StackPanel Spacing="2">
        <TextBlock FontSize="18" FontWeight="Bold" Margin="8,16,8,24">
          <Run Text="lucid" FontStyle="Italic" Foreground="{DynamicResource LrAccentBlueBrush}"/><Run Text="RESUME" Foreground="{DynamicResource LrPrimaryTextBrush}"/>
        </TextBlock>

        <!-- Notification badge -->
        <Border Background="{DynamicResource LrAccentBlueBgBrush}" CornerRadius="6" Padding="8,4" Margin="0,0,0,8"
                IsVisible="{Binding HasNotifications}">
          <StackPanel Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <Border Background="{DynamicResource LrAccentBlueBrush}" CornerRadius="8" Padding="5,1" MinWidth="20"
                      HorizontalAlignment="Center">
                <TextBlock Text="{Binding NotificationCount}" FontSize="10" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
              </Border>
              <TextBlock Text="new jobs" FontSize="10" Foreground="{DynamicResource LrAccentBlueBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="{Binding NotificationMessage}" FontSize="8" Foreground="{DynamicResource LrSecondaryTextBrush}"
                       TextWrapping="Wrap" MaxWidth="170"
                       IsVisible="{Binding NotificationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          </StackPanel>
        </Border>

        <!-- Each nav item: accent border + transparent button in a Panel -->
        <Panel>
          <Border CornerRadius="4" Background="{DynamicResource LrNavHoverBgBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=Resume}"/>
          <Border CornerRadius="4,0,0,4" Width="3" HorizontalAlignment="Left" Background="{DynamicResource LrNavAccentBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=Resume}"/>
          <Button Classes="nav-btn" Content="My CV"
                  Command="{Binding NavigateCommand}" CommandParameter="Resume"/>
        </Panel>
        <Panel>
          <Border CornerRadius="4" Background="{DynamicResource LrNavHoverBgBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=MyData}"/>
          <Border CornerRadius="4,0,0,4" Width="3" HorizontalAlignment="Left" Background="{DynamicResource LrNavAccentBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=MyData}"/>
          <Button Classes="nav-btn" Content="My Data"
                  Command="{Binding NavigateCommand}" CommandParameter="MyData"/>
        </Panel>
        <Panel>
          <Border CornerRadius="4" Background="{DynamicResource LrNavHoverBgBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=Career}"/>
          <Border CornerRadius="4,0,0,4" Width="3" HorizontalAlignment="Left" Background="{DynamicResource LrNavAccentBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=Career}"/>
          <Button Classes="nav-btn" Content="Career"
                  Command="{Binding NavigateCommand}" CommandParameter="Career"/>
        </Panel>
        <Panel>
          <Border CornerRadius="4" Background="{DynamicResource LrNavHoverBgBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=Jobs}"/>
          <Border CornerRadius="4,0,0,4" Width="3" HorizontalAlignment="Left" Background="{DynamicResource LrNavAccentBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=Jobs}"/>
          <Button Classes="nav-btn" Content="Jobs"
                  Command="{Binding NavigateCommand}" CommandParameter="Jobs"/>
        </Panel>
        <Panel>
          <Border CornerRadius="4" Background="{DynamicResource LrNavHoverBgBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=Search}"/>
          <Border CornerRadius="4,0,0,4" Width="3" HorizontalAlignment="Left" Background="{DynamicResource LrNavAccentBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=Search}"/>
          <Button Classes="nav-btn" Content="Add Job"
                  Command="{Binding NavigateCommand}" CommandParameter="Search"/>
        </Panel>
        <Panel>
          <Border CornerRadius="4" Background="{DynamicResource LrNavHoverBgBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=Apply}"/>
          <Border CornerRadius="4,0,0,4" Width="3" HorizontalAlignment="Left" Background="{DynamicResource LrNavAccentBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=Apply}"/>
          <Button Classes="nav-btn" Content="Apply"
                  Command="{Binding NavigateCommand}" CommandParameter="Apply"/>
        </Panel>
        <Panel>
          <Border CornerRadius="4" Background="{DynamicResource LrNavHoverBgBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=Pipeline}"/>
          <Border CornerRadius="4,0,0,4" Width="3" HorizontalAlignment="Left" Background="{DynamicResource LrNavAccentBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=Pipeline}"/>
          <Button Classes="nav-btn" Content="Pipeline"
                  Command="{Binding NavigateCommand}" CommandParameter="Pipeline"/>
        </Panel>
        <Panel>
          <Border CornerRadius="4" Background="{DynamicResource LrNavHoverBgBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=Profile}"/>
          <Border CornerRadius="4,0,0,4" Width="3" HorizontalAlignment="Left" Background="{DynamicResource LrNavAccentBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=Profile}"/>
          <Button Classes="nav-btn" Content="Profile"
                  Command="{Binding NavigateCommand}" CommandParameter="Profile"/>
        </Panel>

        <!-- Separator before Help -->
        <Border Height="1" Background="{DynamicResource LrBorderBrush}" Margin="8,8"/>

        <Panel>
          <Border CornerRadius="4" Background="{DynamicResource LrNavHoverBgBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=Help}"/>
          <Border CornerRadius="4,0,0,4" Width="3" HorizontalAlignment="Left" Background="{DynamicResource LrNavAccentBrush}"
                  IsVisible="{Binding SelectedNav, Converter={StaticResource NavIsActive}, ConverterParameter=Help}"/>
          <Button Classes="nav-btn" Content="? Help"
                  Command="{Binding NavigateCommand}" CommandParameter="Help"/>
        </Panel>
      </StackPanel>
      </DockPanel>
    </Border>

    <!-- Main content area -->
    <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"/>

  </Grid>
</Window>
