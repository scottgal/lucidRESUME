{
  "Collabora": {
    "Enabled": false,
    "CodeUrl": "http://localhost:9980",
    "WopiPort": 9981,
    "HostUrl": "http://localhost:9981"
  },
  "Docling": {
    "Enabled": false,
    "BaseUrl": "http://localhost:5001",
    "UseCloud": false,
    "CloudBaseUrl": "https://docling-serve.eu-de.direct.cloud.ibm.com",
    "CloudApiKey": "",
    "TimeoutSeconds": 120,
    "PollIntervalMs": 2000
  },
  "Embedding": {
    "Provider": "onnx",
    "OnnxModelPath": "models/all-MiniLM-L6-v2.onnx",
    "VocabPath": "models/vocab.txt"
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "qwen3.5:4b",
    "ExtractionModel": "qwen3.5:0.8b",
    "EmbeddingModel": "nomic-embed-text",
    "NumCtx": 16384
  },
  "Tailoring": {
    "TermNormalizationMinSimilarity": 0.85
  },
  "Coverage": {
    "SkillSemanticThreshold": 0.82,
    "ResponsibilitySemanticThreshold": 0.75,
    "MinKeywordOverlap": 2,
    "MinKeywordLength": 4
  },
  "Adzuna": {
    "AppId": "",
    "AppKey": "",
    "Country": "gb"
  },
  "Reed": {
    "ApiKey": ""
  },
  "Findwork": {
    "ApiKey": ""
  },
  "OnnxNer": {
    "ModelPath": "",
    "VocabPath": "",
    "ConfidenceThreshold": 0.70,
    "MaxSequenceLength": 512
  },
  "CloudflareBrowserRendering": {
    "AccountId": "",
    "ApiToken": "",
    "WaitUntil": "networkidle0"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
